# Doopify environment template
# Copy this file to .env (for DB URLs) and .env.local (for secrets).
# Use fake placeholders only. Never commit real credentials.
#
# Recommended local split:
#   .env        → DATABASE_URL, DIRECT_URL, DATABASE_URL_TEST
#   .env.local  → everything else (runtime secrets, provider keys)
#
# Production:
#   Set values in your host secret manager (e.g. Vercel environment variables).
#   Do not copy .env.local into git.
#
# Generate random secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# -----------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------
DATABASE_URL="postgresql://doopify_user:replace_me@localhost:5432/doopify_dev?sslmode=disable"
DIRECT_URL="postgresql://doopify_user:replace_me@localhost:5432/doopify_dev?sslmode=disable"

# Production: use sslmode=verify-full for Neon or hosted Postgres.

JWT_SECRET="replace_with_a_random_secret_at_least_32_chars"
ENCRYPTION_KEY="replace_with_a_random_secret_at_least_32_chars"
# ENCRYPTION_KEY is required for encrypted integration secrets.
# Changing it after credentials are saved will break existing encrypted values.

NEXT_PUBLIC_STORE_URL="http://localhost:3000"
# Production: set to your public storefront URL, e.g. https://yourstore.vercel.app

# -----------------------------------------------------------------------
# Stripe (required for checkout)
# -----------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
# STRIPE_WEBHOOK_SECRET: get from Stripe Dashboard → Webhooks → your endpoint → Signing secret.
# Run: npm run doopify:stripe:webhook  to register the endpoint and get the secret.

# -----------------------------------------------------------------------
# Job and webhook runner secrets (required for background processing)
# -----------------------------------------------------------------------
WEBHOOK_RETRY_SECRET="replace_with_a_random_secret_at_least_16_chars"
# Protects: POST /api/webhook-retries/run

JOB_RUNNER_SECRET="replace_with_a_random_secret_at_least_16_chars"
# Protects: POST /api/jobs/run
# If omitted, falls back to WEBHOOK_RETRY_SECRET.

ABANDONED_CHECKOUT_SECRET="replace_with_a_random_secret_at_least_16_chars"
# Protects: POST /api/abandoned-checkouts/send-due
# If omitted, falls back to WEBHOOK_RETRY_SECRET.

OWNER_MFA_GRACE_PERIOD_DAYS="14"
# Optional owner MFA grace period in days. Used for phased rollout guidance.

# -----------------------------------------------------------------------
# Email provider (choose one — optional for private beta)
# -----------------------------------------------------------------------
# Option A: Resend (recommended)
RESEND_API_KEY="re_replace_me"
RESEND_WEBHOOK_SECRET="whsec_replace_me"
# RESEND_WEBHOOK_SECRET: register https://<your-domain>/api/webhooks/email-provider
# Subscribe to: email.bounced, email.complained

# Option B: SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USERNAME="smtp-user"
SMTP_PASSWORD="replace_me"
SMTP_FROM_EMAIL="noreply@example.com"

# If neither is configured, the system runs in preview mode:
# email delivery records are created and marked FAILED with
# "No email provider configured". No live sends occur.

# -----------------------------------------------------------------------
# Shipping providers (optional — only needed for live carrier rates)
# -----------------------------------------------------------------------
SHIPPO_API_KEY="shippo_test_replace_me"
EASYPOST_API_KEY="EZTK_replace_me"
SHIPPO_WEBHOOK_SECRET="shippo_whsec_replace_me"
EASYPOST_WEBHOOK_SECRET="easypost_whsec_replace_me"
# These can also be saved via Settings → Shipping & delivery in the admin.
# Manual flat rates work without a live provider.

# -----------------------------------------------------------------------
# Media / object storage (optional — Postgres is default)
# -----------------------------------------------------------------------
# MEDIA_STORAGE_PROVIDER=postgres  # default — stores binary in MediaAsset.data
# MEDIA_STORAGE_PROVIDER=s3        # use S3-compatible object storage (R2, AWS)

# Required when MEDIA_STORAGE_PROVIDER=s3:
# MEDIA_S3_REGION="auto"
# MEDIA_S3_BUCKET="your-bucket-name"
# MEDIA_S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"  # Cloudflare R2
# MEDIA_S3_ACCESS_KEY_ID="replace_me"
# MEDIA_S3_SECRET_ACCESS_KEY="replace_me"
# MEDIA_S3_PUBLIC_URL="https://your-cdn-domain.com"  # optional CDN prefix

# -----------------------------------------------------------------------
# Security headers (optional — production defaults are safe)
# -----------------------------------------------------------------------
# SECURITY_HEADERS_ENABLED=false   # emergency rollback: disable all security headers
# CSP_MODE=off                      # off | report-only (default) | enforce

# -----------------------------------------------------------------------
# Rate limiting (optional — auto-defaults to postgres in production)
# -----------------------------------------------------------------------
# DOOPIFY_RATE_LIMIT_STORE=postgres  # explicit for multi-instance deployments

# -----------------------------------------------------------------------
# First-owner bootstrap (production only)
# -----------------------------------------------------------------------
SETUP_TOKEN="replace_with_a_random_token_for_production_bootstrap"
# Required in production (NODE_ENV=production) when creating the first owner.
# Revoke (remove or change) this value after owner creation.
# Not required in development.

# -----------------------------------------------------------------------
# Setup/CLI bootstrap helpers (used by doopify setup / db:seed:bootstrap)
# -----------------------------------------------------------------------
DOOPIFY_STORE_NAME="Doopify Demo Store"
DOOPIFY_STORE_EMAIL="owner@example.com"
DOOPIFY_ADMIN_EMAIL="owner@example.com"
DOOPIFY_ADMIN_PASSWORD="replace_with_a_strong_temp_password"

# -----------------------------------------------------------------------
# Deployment automation helpers (doopify env push / doopify deploy)
# -----------------------------------------------------------------------
VERCEL_TOKEN="replace_me"
VERCEL_PROJECT_ID="replace_me"
VERCEL_PROJECT_NAME="optional-project-name"
VERCEL_TEAM_ID="optional-team-id"
VERCEL_TEAM_SLUG="optional-team-slug"

# -----------------------------------------------------------------------
# Test only — never point at dev or production database
# -----------------------------------------------------------------------
DATABASE_URL_TEST="postgresql://doopify_user:replace_me@localhost:5432/doopify_test?sslmode=disable"
