generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  CATALOG_MANAGER
  ORDERS_MANAGER
  FULFILLMENT
  SUPPORT
  ANALYST
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum MediaAssetType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaAssetStatus {
  READY
  PROCESSING
  ARCHIVED
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderSource {
  ONLINE_STORE
  ADMIN
  DRAFT_ORDER
  POS
  INSTAGRAM
  IMPORT
}

enum OrderFinancialStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOIDED
}

enum OrderFulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
  RETURNED
}

enum OrderDisplayStatus {
  OPEN
  ARCHIVED
  CANCELED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum FulfillmentStatus {
  PENDING
  PACKED
  SHIPPED
  DELIVERED
  READY_FOR_PICKUP
  RETURNED
  CANCELED
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  COMPLETED
  REJECTED
}

enum EventActorType {
  SYSTEM
  USER
  CUSTOMER
}

enum IntegrationType {
  STRIPE
  SMTP
  SHIPPING
  STORAGE
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

model Store {
  id                      String                  @id @default(cuid())
  name                    String
  supportEmail            String?
  phone                   String?
  currency                String                  @default("USD")
  timezone                String                  @default("America/New_York")
  logoUrl                 String?
  brandPrimary            String?                 @default("#6d28d9")
  brandAccent             String?                 @default("#a855f7")
  orderPrefix             String                  @default("DPY")
  nextOrderSequence       Int                     @default(1000)
  defaultLocation         String?
  shippingOrigin          String?
  freeShippingThreshold   Decimal?                @db.Decimal(10, 2)
  senderEmail             String?
  lowInventoryAlert       Int?                    @default(5)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  users                   User[]
  sessions                Session[]
  products                Product[]
  customers               Customer[]
  orders                  Order[]
  payments                Payment[]
  mediaAssets             MediaAsset[]
  integrationConnections  IntegrationConnection[]
}

model User {
  id             String       @id @default(cuid())
  storeId        String
  email          String       @unique
  firstName      String?
  lastName       String?
  passwordHash   String
  role           UserRole     @default(ADMIN)
  status         UserStatus   @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessions       Session[]
  uploadedMedia  MediaAsset[] @relation("UploadedMediaBy")
  orderEvents    OrderEvent[] @relation("OrderEventUser")
}

model Session {
  id         String   @id @default(cuid())
  storeId    String
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id           String           @id @default(cuid())
  storeId      String
  title        String
  handle       String           @unique
  description  String?
  status       ProductStatus    @default(DRAFT)
  publishedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  store        Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants     ProductVariant[]
  media        ProductMedia[]
  orderItems   OrderItem[]
}

model ProductVariant {
  id                 String      @id @default(cuid())
  productId          String
  title              String
  sku                String?
  price              Decimal     @db.Decimal(10, 2)
  compareAtPrice     Decimal?    @db.Decimal(10, 2)
  inventoryQuantity  Int         @default(0)
  weightGrams        Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
}

model Customer {
  id             String         @id @default(cuid())
  storeId        String
  email          String?
  firstName      String?
  lastName       String?
  phone          String?
  totalSpent     Decimal        @default(0) @db.Decimal(12, 2)
  orderCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@unique([storeId, email])
}

model Order {
  id                    String                  @id @default(cuid())
  storeId               String
  customerId            String?
  orderNumber           String                  @unique
  displayStatus         OrderDisplayStatus      @default(OPEN)
  source                OrderSource             @default(ONLINE_STORE)
  financialStatus       OrderFinancialStatus    @default(PENDING)
  fulfillmentStatus     OrderFulfillmentStatus  @default(UNFULFILLED)
  currency              String                  @default("USD")
  customerEmail         String?
  customerPhone         String?
  note                  String?
  tags                  String[]                @default([])
  subtotalAmount        Decimal                 @default(0) @db.Decimal(12, 2)
  discountAmount        Decimal                 @default(0) @db.Decimal(12, 2)
  shippingAmount        Decimal                 @default(0) @db.Decimal(12, 2)
  taxAmount             Decimal                 @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal                 @default(0) @db.Decimal(12, 2)
  placedAt              DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  store                 Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer              Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  addresses             OrderAddress[]
  fulfillments          Fulfillment[]
  payments              Payment[]
  refunds               Refund[]
  returns               Return[]
  events                OrderEvent[]

  @@index([storeId, createdAt])
  @@index([storeId, financialStatus])
  @@index([storeId, fulfillmentStatus])
}

model OrderItem {
  id               String              @id @default(cuid())
  orderId          String
  productId        String?
  variantId        String?
  title            String
  variantTitle     String?
  sku              String?
  quantity         Int                 @default(1)
  unitPrice        Decimal             @db.Decimal(12, 2)
  lineTotal        Decimal             @db.Decimal(12, 2)
  order            Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: SetNull)
  fulfillmentItems FulfillmentItem[]
  returnItems      ReturnItem[]
}

model OrderAddress {
  id          String      @id @default(cuid())
  orderId     String
  type        AddressType
  firstName   String?
  lastName    String?
  company     String?
  address1    String
  address2    String?
  city        String
  province    String?
  postalCode  String?
  country     String
  phone       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, type])
}

model Fulfillment {
  id             String              @id @default(cuid())
  orderId        String
  status         FulfillmentStatus   @default(PENDING)
  locationName   String?
  carrier        String?
  service        String?
  trackingNumber String?
  trackingUrl    String?
  labelUrl       String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  order          Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          FulfillmentItem[]

  @@index([orderId, status])
}

model FulfillmentItem {
  id             String        @id @default(cuid())
  fulfillmentId  String
  orderItemId    String
  quantity       Int           @default(1)
  createdAt      DateTime      @default(now())
  fulfillment    Fulfillment   @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem      OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([fulfillmentId])
  @@index([orderItemId])
}

model Payment {
  id                String          @id @default(cuid())
  storeId           String
  orderId           String?
  provider          PaymentProvider @default(STRIPE)
  providerPaymentId String?
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("USD")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  store             Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order             Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  refunds           Refund[]

  @@index([orderId])
}

model Refund {
  id          String      @id @default(cuid())
  orderId     String
  paymentId   String?
  amount      Decimal     @db.Decimal(12, 2)
  reason      String?
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment     Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Return {
  id          String        @id @default(cuid())
  orderId     String
  status      ReturnStatus  @default(REQUESTED)
  reason      String?
  receivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items       ReturnItem[]

  @@index([orderId, status])
}

model ReturnItem {
  id          String      @id @default(cuid())
  returnId    String
  orderItemId String
  quantity    Int         @default(1)
  condition   String?
  restocked   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  return      Return      @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([orderItemId])
}

model OrderEvent {
  id          String          @id @default(cuid())
  orderId     String
  actorType   EventActorType  @default(SYSTEM)
  userId      String?
  title       String
  detail      String?
  eventType   String
  createdAt   DateTime        @default(now())
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User?           @relation("OrderEventUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
}

model MediaAsset {
  id            String           @id @default(cuid())
  storeId       String
  uploadedById  String?
  type          MediaAssetType   @default(IMAGE)
  status        MediaAssetStatus @default(READY)
  title         String?
  altText       String?
  originalName  String
  storagePath   String
  mimeType      String
  sizeBytes     Int
  width         Int?
  height        Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  uploadedBy    User?            @relation("UploadedMediaBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  productLinks  ProductMedia[]
}

model ProductMedia {
  id           String     @id @default(cuid())
  productId    String
  mediaAssetId String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([productId, mediaAssetId])
}

model IntegrationConnection {
  id             String            @id @default(cuid())
  storeId        String
  type           IntegrationType
  label          String
  status         IntegrationStatus @default(DISCONNECTED)
  configJson     Json?
  lastCheckedAt  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  secrets        IntegrationSecret[]

  @@unique([storeId, type, label])
}

model IntegrationSecret {
  id             String                @id @default(cuid())
  connectionId   String
  key            String
  valueEncrypted String
  last4          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  connection     IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, key])
}
