generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF
  VIEWER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOIDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
  RESTOCKED
}

enum FulfillmentState {
  PENDING
  OPEN
  SUCCESS
  CANCELLED
  ERROR
  FAILURE
}

enum DiscountType {
  CODE
  AUTOMATIC
}

enum DiscountMethod {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum ShippingRateMethod {
  FLAT
  SUBTOTAL_TIER
}

enum DiscountStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  DISABLED
}

enum OrderAddressType {
  SHIPPING
  BILLING
}

enum OrderEventActorType {
  SYSTEM
  STAFF
  CUSTOMER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CLOSED
  DECLINED
}

enum CheckoutSessionStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSED
  FAILED
  SIGNATURE_FAILED
  RETRY_PENDING
  RETRY_EXHAUSTED
}

enum RefundStatus {
  PENDING
  ISSUED
  FAILED
}

model Store {
  id                String   @id @default(cuid())
  name              String
  email             String?
  phone             String?
  domain            String?  @unique
  currency          String   @default("USD")
  timezone          String   @default("America/New_York")
  logoUrl           String?
  primaryColor      String   @default("#000000")
  secondaryColor    String   @default("#ffffff")
  address1          String?
  address2          String?
  city              String?
  province          String?
  postalCode        String?
  country           String?
  shippingThreshold Float?
  shippingDomesticRate Float   @default(9.99)
  shippingInternationalRate Float @default(19.99)
  domesticTaxRate   Float   @default(0.07)
  internationalTaxRate Float @default(0.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  shippingZones     ShippingZone[]
  taxRules          TaxRule[]

  @@map("stores")
}

model ShippingZone {
  id          String         @id @default(cuid())
  storeId     String
  name        String
  countryCode String
  provinceCode String?
  isActive    Boolean        @default(true)
  priority    Int            @default(100)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  store       Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rates       ShippingRate[]

  @@index([storeId, isActive, priority])
  @@index([countryCode, provinceCode])
  @@map("shipping_zones")
}

model ShippingRate {
  id             String             @id @default(cuid())
  shippingZoneId String
  name           String
  method         ShippingRateMethod @default(FLAT)
  amount         Float
  minSubtotal    Float?
  maxSubtotal    Float?
  isActive       Boolean            @default(true)
  priority       Int                @default(100)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  shippingZone   ShippingZone       @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)

  @@index([shippingZoneId, isActive, priority])
  @@map("shipping_rates")
}

model TaxRule {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  countryCode  String
  provinceCode String?
  rate         Float
  isActive     Boolean  @default(true)
  priority     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive, priority])
  @@index([countryCode, provinceCode])
  @@map("tax_rules")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Product {
  id          String        @id @default(cuid())
  title       String
  handle      String        @unique
  status      ProductStatus @default(DRAFT)
  description String?       @db.Text
  vendor      String?
  productType String?
  tags        String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  variants    ProductVariant[]
  options     ProductOption[]
  media       ProductMedia[]
  collections CollectionProduct[]
  orderItems  OrderItem[]

  @@index([handle])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id               String            @id @default(cuid())
  productId        String
  title            String
  sku              String?           @unique
  price            Float
  compareAtPrice   Float?
  inventory        Int               @default(0)
  weight           Float?
  weightUnit       String?           @default("kg")
  position         Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  fulfillmentItems FulfillmentItem[]
  orderItems       OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductOption {
  id        String               @id @default(cuid())
  productId String
  name      String
  position  Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@index([productId])
  @@map("product_options")
}

model ProductOptionValue {
  id       String        @id @default(cuid())
  optionId String
  value    String
  position Int           @default(0)
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
  @@map("product_option_values")
}

model MediaAsset {
  id           String         @id @default(cuid())
  filename     String
  altText      String?
  mimeType     String         @default("application/octet-stream")
  size         Int?
  width        Int?
  height       Int?
  data         Bytes
  createdAt    DateTime       @default(now())
  productMedia ProductMedia[]

  @@map("media_assets")
}

model ProductMedia {
  id         String     @id @default(cuid())
  productId  String
  assetId    String
  position   Int        @default(0)
  isFeatured Boolean    @default(false)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([productId, assetId])
  @@index([productId])
  @@map("product_media")
}

model Collection {
  id          String              @id @default(cuid())
  title       String
  handle      String              @unique
  description String?             @db.Text
  imageUrl    String?
  sortOrder   String              @default("MANUAL")
  isAutomated Boolean             @default(false)
  isPublished Boolean             @default(true)
  conditions  Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    CollectionProduct[]

  @@index([handle])
  @@map("collections")
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@map("collection_products")
}

model Customer {
  id               String            @id @default(cuid())
  email            String            @unique
  firstName        String?
  lastName         String?
  phone            String?
  passwordHash     String?
  acceptsMarketing Boolean           @default(false)
  tags             String[]
  note             String?
  totalSpent       Float             @default(0)
  orderCount       Int               @default(0)
  defaultAddressId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  addresses        CustomerAddress[]
  checkoutSessions CheckoutSession[]
  orders           Order[]

  @@index([email])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  firstName  String?
  lastName   String?
  company    String?
  address1   String?
  address2   String?
  city       String?
  province   String?
  postalCode String?
  country    String?
  phone      String?
  isDefault  Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model Order {
  id                   String                @id @default(cuid())
  orderNumber          Int                   @unique @default(autoincrement())
  customerId           String?
  email                String?
  status               OrderStatus           @default(OPEN)
  paymentStatus        PaymentStatus         @default(PENDING)
  fulfillmentStatus    FulfillmentStatus     @default(UNFULFILLED)
  subtotal             Float                 @default(0)
  taxAmount            Float                 @default(0)
  shippingAmount       Float                 @default(0)
  discountAmount       Float                 @default(0)
  total                Float                 @default(0)
  currency             String                @default("USD")
  channel              String                @default("online")
  note                 String?
  tags                 String[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customer             Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  addresses            OrderAddress[]
  payments             Payment[]
  fulfillments         Fulfillment[]
  events               OrderEvent[]
  refunds              Refund[]
  returns              Return[]
  discountApplications DiscountApplication[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id               String           @id @default(cuid())
  orderId          String
  productId        String?
  variantId        String?
  title            String
  variantTitle     String?
  sku              String?
  price            Float
  quantity         Int
  totalDiscount    Float            @default(0)
  total            Float
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  fulfillmentItems FulfillmentItem[]

  @@index([orderId])
  @@map("order_items")
}

model OrderAddress {
  id         String           @id @default(cuid())
  orderId    String
  type       OrderAddressType
  firstName  String?
  lastName   String?
  company    String?
  address1   String?
  address2   String?
  city       String?
  province   String?
  postalCode String?
  country    String?
  phone      String?
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_addresses")
}

model OrderEvent {
  id        String              @id @default(cuid())
  orderId   String
  type      String
  title     String
  detail    String?
  actorType OrderEventActorType @default(SYSTEM)
  actorId   String?
  createdAt DateTime            @default(now())
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_events")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  provider              String        @default("stripe")
  amount                Float
  currency              String        @default("USD")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  receiptUrl            String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds               Refund[]

  @@index([orderId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

model CheckoutSession {
  id              String                @id @default(cuid())
  paymentIntentId String                @unique
  customerId      String?
  email           String?
  status          CheckoutSessionStatus @default(PENDING)
  currency        String                @default("USD")
  subtotal        Float                 @default(0)
  taxAmount       Float                 @default(0)
  shippingAmount  Float                 @default(0)
  discountAmount  Float                 @default(0)
  total           Float                 @default(0)
  payload         Json
  failureReason   String?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  customer        Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("checkout_sessions")
}

model WebhookDelivery {
  id              String                @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  status          WebhookDeliveryStatus @default(RECEIVED)
  attempts        Int                   @default(1)
  processedAt     DateTime?
  lastError       String?
  payloadHash     String
  rawPayload      String?               @db.Text
  nextRetryAt     DateTime?
  lastRetriedAt   DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([provider, providerEventId])
  @@index([provider, eventType])
  @@index([status, createdAt])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model Fulfillment {
  id             String           @id @default(cuid())
  orderId        String
  status         FulfillmentState @default(PENDING)
  locationName   String?
  carrier        String?
  service        String?
  trackingNumber String?
  trackingUrl    String?
  labelUrl       String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          FulfillmentItem[]

  @@index([orderId])
  @@map("fulfillments")
}

model FulfillmentItem {
  id            String          @id @default(cuid())
  fulfillmentId String
  orderItemId   String
  variantId     String?
  quantity      Int
  fulfillment   Fulfillment     @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem     OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([fulfillmentId])
  @@map("fulfillment_items")
}

model Refund {
  id             String       @id @default(cuid())
  orderId        String
  paymentId      String?
  stripeRefundId String?      @unique
  status         RefundStatus @default(PENDING)
  amount         Float
  reason         String?
  note           String?
  restockItems   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment        Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  items          RefundItem[]
  returnSource   Return?

  @@index([orderId])
  @@map("refunds")
}

model RefundItem {
  id          String  @id @default(cuid())
  refundId    String
  orderItemId String
  variantId   String?
  quantity    Int
  amount      Float
  refund      Refund  @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId])
  @@map("refund_items")
}

model Return {
  id         String       @id @default(cuid())
  orderId    String
  refundId   String?      @unique
  status     ReturnStatus @default(REQUESTED)
  reason     String?
  note       String?
  receivedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refund     Refund?      @relation(fields: [refundId], references: [id], onDelete: SetNull)
  items      ReturnItem[]

  @@index([orderId])
  @@map("returns")
}

model ReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  orderItemId String
  variantId   String?
  quantity    Int
  reason      String?
  return      Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("return_items")
}

model Discount {
  id                    String                @id @default(cuid())
  code                  String?               @unique
  title                 String
  type                  DiscountType          @default(CODE)
  method                DiscountMethod        @default(PERCENTAGE)
  value                 Float
  minimumOrder          Float?
  usageLimit            Int?
  usageCount            Int                   @default(0)
  status                DiscountStatus        @default(ACTIVE)
  startsAt              DateTime?
  endsAt                DateTime?
  combinesWithOrders    Boolean               @default(false)
  combinesWithProducts  Boolean               @default(false)
  combinesWithShipping  Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  applications          DiscountApplication[]

  @@index([code])
  @@index([status])
  @@map("discounts")
}

model DiscountApplication {
  id         String   @id @default(cuid())
  orderId    String
  discountId String
  amount     Float
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@unique([orderId, discountId])
  @@map("discount_applications")
}

model Integration {
  id            String             @id @default(cuid())
  name          String
  type          String             @default("CUSTOM")
  webhookUrl    String?
  webhookSecret String?
  status        IntegrationStatus  @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  events        IntegrationEvent[]
  secrets       IntegrationSecret[]
  deliveries    OutboundWebhookDelivery[]

  @@map("integrations")
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
}

model IntegrationEvent {
  id            String      @id @default(cuid())
  integrationId String
  event         String      // e.g., "order.paid"
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("integration_events")
}

model IntegrationSecret {
  id            String      @id @default(cuid())
  integrationId String
  key           String      // e.g., "API_KEY"
  value         String      @db.Text // Encrypted value
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, key])
  @@map("integration_secrets")
}

model OutboundWebhookDelivery {
  id            String                @id @default(cuid())
  integrationId String
  event         String
  payload       String                @db.Text
  status        OutboundDeliveryStatus @default(PENDING)
  statusCode    Int?
  responseBody  String?               @db.Text
  attempts      Int                   @default(0)
  lastRetriedAt DateTime?
  nextRetryAt   DateTime?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, status])
  @@index([status, nextRetryAt])
  @@map("outbound_webhook_deliveries")
}

enum OutboundDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
  EXHAUSTED
}
